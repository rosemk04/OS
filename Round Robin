#include <stdio.h>

int main() {
    int n, i, j;
    int pid[10], at[10], bt[10], wt[10], tat[10], remaining_bt[10];
    int total_wt = 0, total_tat = 0, time_quantum, time = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    // Input Arrival Time, Burst Time for each process
    for (i = 0; i < n; i++) {
        pid[i] = i + 1;
        printf("Arrival time of P%d: ", pid[i]);
        scanf("%d", &at[i]);
        printf("Burst time of P%d: ", pid[i]);
        scanf("%d", &bt[i]);
        remaining_bt[i] = bt[i];  // Initialize remaining burst time to burst time
    }

    // Input Time Quantum
    printf("Enter Time Quantum: ");
    scanf("%d", &time_quantum);

    // Round Robin Scheduling
    int completed = 0, curr_time = 0;
    while (completed < n) {
        for (i = 0; i < n; i++) {
            if (remaining_bt[i] > 0) {
                // If the process has arrived and is not completed
                if (at[i] <= curr_time) {
                    if (remaining_bt[i] > time_quantum) {
                        // Process executes for the time quantum
                        curr_time += time_quantum;
                        remaining_bt[i] -= time_quantum;
                    } else {
                        // Process finishes execution
                        curr_time += remaining_bt[i];
                        wt[i] = curr_time - at[i] - bt[i];  // Waiting time = finish time - arrival time - burst time
                        tat[i] = wt[i] + bt[i];  // Turnaround time = waiting time + burst time
                        total_wt += wt[i];
                        total_tat += tat[i];
                        remaining_bt[i] = 0;  // Mark process as completed
                        completed++;
                    }
                }
            }
        }
    }

    // Display results
    printf("\nPID\tAT\tBT\tWT\tTAT\n");
    for (i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\n", pid[i], at[i], bt[i], wt[i], tat[i]);
    }

    printf("\nAverage Waiting Time = %.2f", (float)total_wt / n);
    printf("\nAverage Turnaround Time = %.2f\n", (float)total_tat / n);

    return 0;
}
