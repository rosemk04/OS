#include <stdio.h>
#include <stdlib.h>
#define MAX 1000

/* FIFO */
int fifo(int ref[], int n, int frames) {
    int frame[10], front = 0, faults = 0;

    for (int i = 0; i < frames; i++)
        frame[i] = -1;

    for (int i = 0; i < n; i++) {
        int found = 0;

        for (int j = 0; j < frames; j++) {
            if (frame[j] == ref[i]) {
                found = 1;
                break;
            }
        }
        if (!found) {
            frame[front] = ref[i];
            front = (front + 1) % frames;
            faults++;
        }
    }
    return faults;
}
/* LRU */
int lru(int ref[], int n, int frames) {
    int frame[10], time[10];
    int faults = 0, t = 0;

    for (int i = 0; i < frames; i++) {
        frame[i] = -1;
        time[i] = -1;   // IMPORTANT FIX
    }
    for (int i = 0; i < n; i++) {
        int found = 0;

        for (int j = 0; j < frames; j++) {
            if (frame[j] == ref[i]) {
                found = 1;
                time[j] = ++t;
                break;
            }
        }
        if (!found) {
            int lru_index = 0;

            for (int j = 1; j < frames; j++) {
                if (time[j] < time[lru_index])
                    lru_index = j;
            }
            frame[lru_index] = ref[i];
            time[lru_index] = ++t;
            faults++;
        }
    }
    return faults;
}
/* Optimal */
int optimal(int ref[], int n, int frames) {
    int frame[10];
    int faults = 0;
    for (int i = 0; i < frames; i++)
        frame[i] = -1;
    for (int i = 0; i < n; i++) {
        int found = 0;

        for (int j = 0; j < frames; j++) {
            if (frame[j] == ref[i]) {
                found = 1;
                break;
            }
        }
        if (!found) {
            int pos = -1, farthest = -1;

            for (int j = 0; j < frames; j++) {
                int k;
                for (k = i + 1; k < n; k++) {
                    if (frame[j] == ref[k])
                        break;
                }
                if (k == n) {   // not used again
                    pos = j;
                    break;
                }
                if (k > farthest) {
                    farthest = k;
                    pos = j;
                }
            }
            if (pos == -1)
                pos = 0;

            frame[pos] = ref[i];
            faults++;
        }
    }
    return faults;
}

int main() {
    int n, frames;
    int ref[MAX];

    printf("Enter length of reference string: ");
    scanf("%d", &n);

    printf("Enter reference string:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &ref[i]);

    printf("Enter number of frames (1-7): ");
    scanf("%d", &frames);

    // validation
    if (frames < 1 || frames > 7) {
        printf("Invalid number of frames!\n");
        return 0;
    }

    printf("\nReference String:\n");
    for (int i = 0; i < n; i++)
        printf("%d ", ref[i]);
    printf("\n\nPage Faults:\n");
    printf("FIFO: %d\n", fifo(ref, n, frames));
    printf("LRU: %d\n", lru(ref, n, frames));
    printf("Optimal: %d\n", optimal(ref, n, frames));
    return 0;
}
